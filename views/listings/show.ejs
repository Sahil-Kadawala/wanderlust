<%- layout("/layouts/boilerplate") %>
<body>
  <div class="row mt-3">
    <div class="col-8 offset-3">
      <h3>List detail:</h3>
    </div>
    <div class="card col-6 offset-3 show-card">
      <img
        src="<%= list.image %>"
        class="card-img-top show-img"
        alt="listing_image"
      />
      <div class="card-body">
        <p class="card-text">
          <b><%= list.title %></b> <br />
          <%= list.desc %> <br />
          &#8377; <%= list.price.toLocaleString("en-IN") %> <br />
          <%= list.location %>, <%= list.country %>
        </p>
      </div>
    </div>
  </div>
  <div class="btns mb-4">
    <a
      href="/listings/<%= list._id %>/edit"
      class="btn btn-dark row-col-1 offset-3 edit-btn"
    >
      Edit</a
    >
    <form action="/listings/<%= list._id%>?_method=DELETE" method="post">
      <button class="btn btn-dark row-col-1 offset-3">Delete</button>
    </form>
  </div>
</body>
